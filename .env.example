# Copy this file to .env and fill in your values.
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=your-generated-secret-key-here

# Optional: Database URL (default: SQLite)
# DATABASE_URL=postgresql://user:pass@host/dbname

# Optional: Session settings
# SESSION_DAYS=7
# SESSION_TIMEOUT_MINUTES=60
# SESSION_COOKIE_SECURE=true

# Optional: Backup email
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM=
# BACKUP_EMAIL_TO=

# Optional: Scheduled backup
# BACKUP_SCHEDULE_ENABLED=false
# BACKUP_SCHEDULE_TIME=02:00
# BACKUP_INCLUDE_UPLOADS=true
# Set false on Render if files are on R2 only (faster, smaller ZIP)
# BACKUP_EXCLUDE_TABLES=activity_log,client_activity_log,login_log,login_attempt

# Optional: Timezone (default: Asia/Karachi)
# APP_TIMEZONE=Asia/Karachi

# --- Optional: public URL (R2 CORS sync on startup uses these) ---
# APP_BASE_URL=https://your-app.onrender.com
# PUBLIC_BASE_URL=https://your-app.onrender.com
# RENDER_EXTERNAL_URL=https://your-app.onrender.com
# R2_CORS_ALLOWED_ORIGINS=https://a.com,https://b.com
# R2_AUTO_SYNC_CORS=true

# --- Optional: Cloudflare R2 (file uploads) — all required if using R2 ---
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT_URL=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# --- Optional: Firebase push — use file firebase-service-account.json OR this env (JSON string) ---
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# --- Optional: AI assistant (routes_ai / Gemini) ---
# GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# AI_RATE_WINDOW_SECONDS=300
# AI_RATE_LIMIT_PER_WINDOW=25

# --- Optional: OpenRouter (slip OCR — primary, Gemini is fallback) ---
# Get key from: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-exp:free

# --- Optional: Render API (admin system-health: last deploy, service status) ---
# RENDER_API_KEY=rnd_...
# RENDER_SERVICE_ID=srv-...

# --- Optional: misc ---
# FLASK_DEBUG=0
# FLASK_APP=app:app
# PORT=5000
# EXPENSE_ATTACHMENT_MAX_MB=120
# FLEET_PERSONAL_PC_URL=

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fleetNetworkOverlayRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fleet_network_overlay_bg"
    android:clickable="true"
    android:focusable="true"
    android:visibility="gone">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingTop="48dp"
        android:paddingEnd="28dp"
        android:paddingBottom="32dp">

        <ImageView
            android:id="@+id/fleetNetworkLogo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginBottom="28dp"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter"
            android:src="@drawable/splash" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/fleet_network_card_bg"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="28dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/fleet_network_icon_circle">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/fleet_network_error_title"
                    android:src="@drawable/ic_fleet_wifi_off" />
            </FrameLayout>

            <TextView
                android:id="@+id/fleetNetworkTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/fleet_network_error_title"
                android:textColor="@color/fleet_slate_200"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/fleetNetworkMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:lineSpacingExtra="3dp"
                android:text="@string/fleet_network_error_message"
                android:textColor="@color/fleet_slate_400"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/fleetNetworkAutoRetry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="@string/fleet_network_auto_retry"
                android:textColor="@color/fleet_blue_500"
                android:textSize="13sp" />

            <Button
                android:id="@+id/fleetNetworkRetryBtn"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/fleet_network_btn_primary"
                android:stateListAnimator="@null"
                android:text="@string/fleet_network_retry"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
